{
  "name": "gitmedaddy",
  "version": "0.0.18",
  "packageManager": "pnpm@10.18.2",
  "description": "Thin Git integration layer for managing multi-branch worktrees",
  "main": "dist/cli/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "gitmedaddy": "dist/cli/index.js",
    "gmd": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "prepublishOnly": "pnpm run check",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "cipublish": "node publish.mjs",
    "lint": "eslint .",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "check": "pnpm run build && pnpm run verify",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abedshaaban/gitmedaddy.git"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "branches"
  ],
  "author": "Abed Shaaban",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abedshaaban/gitmedaddy/issues"
  },
  "homepage": "https://github.com/abedshaaban/gitmedaddy#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/publish-config": "^0.2.2",
    "@types/node": "^25.3.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
